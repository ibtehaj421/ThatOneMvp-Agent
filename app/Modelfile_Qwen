FROM qwen2.5:7b-instruct-q8_0

# ─── System Prompt ──────────────────────────────────────────────────────────
# This instructs the model to act as a structured medical interviewer.
# It follows the CMAS (Comprehensive Medical Attribute Schema) protocol,
# extracting patient slots and their attributes before asking follow-up questions.

# Note: The system prompt has been moved to app/agent/nodes.py for dynamic state injection.
# We clear the default SYSTEM prompt here to ensure both don't get 'attached' by Ollama.
SYSTEM ""

# ─── Parameters ─────────────────────────────────────────────────────────────
PARAMETER temperature 0.3
PARAMETER top_p 0.9
PARAMETER num_ctx 8192
PARAMETER repeat_penalty 1.1
PARAMETER stop "###END###"
PARAMETER num_batch 1024
